<?xml version="1.0" encoding="utf-8"?>
  <odoo>
      
    <!-- View mrp.bom form -->
    <record id="burgtec_warehouse_customization.view_mrp_bom_form" model="ir.ui.view">
        <field name="name">burgtec.warehouse.customization.view.mrp.bom.form</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="attributes">
              <attribute name="domain" add="[('custom_variant_type','=','component')]" separator=" or "/>
            </xpath>
        </field>
    </record>

  </odoo>